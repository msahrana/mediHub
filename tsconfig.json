{
    "compilerOptions": {
        "outDir": "./dist",

        "target": "ES2023",

        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "types": ["node"],

        "strict": true,

        "sourceMap": true,

        "declaration": false,

        "skipLibCheck": true,

        "esModuleInterop": true,

        "allowSyntheticDefaultImports": true
    },

    "include": ["src/**/*"],
    "exclude": []
}
