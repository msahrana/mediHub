model Review {

  id String @id @default(uuid())

  rating Int

  comment String?

  medicineId String

  customerId String

  medicine Medicine @relation(fields:[medicineId], references:[id])

  customer User @relation(fields:[customerId], references:[id])

  createdAt DateTime @default(now())

  @@unique([medicineId, customerId])

  @@map("Reviews")
}