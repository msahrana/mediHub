model User {
  id          String @id @default(uuid())

  name        String
  email       String @unique
  password    String

  role        Role
  status      UserStatus @default(ACTIVE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile     Profile?

  medicines   Medicine[]

  cartItems   Cart[]

  orders       Order[]
  orderItems   OrderItem[]

  reviews     Review[]

  payments    Payment[]

  @@map("Users")
}