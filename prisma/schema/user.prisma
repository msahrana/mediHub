model User {
  id        String @id @default(uuid())

  name      String
  email     String @unique
  password  String

  role      Role
  status    UserStatus @default(ACTIVE)

  profile   Profile?

  medicines Medicine[] @relation("SellerMedicines")
  orders    Order[]
  reviews   Review[]
  carts     Cart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
