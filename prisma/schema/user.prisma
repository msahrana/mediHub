model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  password     String
  phone        String?
  address      String?
  image        String?
  role         Role
  status       UserStatus   @default(ACTIVE)

  medicines    Medicine[]   @relation("SellerMedicines")
  orders       Order[]
  reviews      Review[]
  carts        Cart[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}