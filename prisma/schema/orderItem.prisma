model OrderItem {

  id String @id @default(uuid())

  orderId String

  medicineId String

  sellerId String

  quantity Int

  price Float

  order Order @relation(fields:[orderId], references:[id])

  medicine Medicine @relation(fields:[medicineId], references:[id])

  seller User @relation(fields:[sellerId], references:[id])

  @@map("OrderItems")
}